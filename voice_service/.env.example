# Voice Service Environment Configuration
# Copy this file to .env and configure for your environment

# Model Configuration
MODEL_PATH=./models
DEVICE=cpu
# MOCK_MODE=true - Set to 'true' for instant mock responses (no GPU needed)
MOCK_MODE=false

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Audio Configuration
SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Performance Configuration
MAX_AUDIO_LENGTH_SECONDS=30
MAX_TEXT_LENGTH=5000
ASR_MAX_LATENCY_MS=500
TRANSLATE_MAX_LATENCY_MS=400
TTS_MAX_LATENCY_MS=600
