# ============================================================================
# VaaNI Multi-Service Environment Configuration
# ============================================================================
# Copy this file to .env and customize for your environment

# ============================================================================
# Service Port Mappings
# ============================================================================
GATEWAY_PORT=8000
VOICE_SERVICE_PORT=8001
LLM_SERVICE_PORT=8002
REDIS_PORT=6379

# ============================================================================
# Gateway Service Configuration
# ============================================================================
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Debug mode (enables auto-reload in development)
DEBUG_MODE=false

# Feature flags for gateway
ENABLE_LID=true
AUTO_TRANSLATE=true
AUTO_SUGGEST=true

# Default language settings
DEFAULT_CUSTOMER_LANGUAGE=en
STAFF_LANGUAGE=en

# Session management
SESSION_TIMEOUT_MINUTES=30
MAX_TRANSCRIPT_ENTRIES=1000

# Retry settings for service calls
MAX_RETRIES=3
RETRY_DELAY_MS=100

# WebSocket settings
WS_MAX_MESSAGE_SIZE=16777216  # 16MB
WS_TIMEOUT=30  # seconds

# ============================================================================
# Voice Service Configuration
# ============================================================================
# ASR (Automatic Speech Recognition)
ENABLE_ASR=true
DEFAULT_ASR_LANGUAGE=en

# LID (Language Identification)
ENABLE_LID=true

# Translation
ENABLE_TRANSLATION=true

# TTS (Text-to-Speech)
ENABLE_TTS=true
DEFAULT_TTS_LANGUAGE=en

# Cache settings
ENABLE_CACHE=true
CACHE_TTL=3600  # seconds

# ============================================================================
# Cloud Service API Keys (Optional)
# ============================================================================
# DeepL Translation API
DEEPL_API_KEY=your_deepl_api_key_here

# Google Cloud Translation
GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

# Azure Speech Services
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# ============================================================================
# LLM Service Configuration
# ============================================================================
# LLM Provider: openai, anthropic, local
LLM_PROVIDER=openai

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Settings (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Local LLM Settings (for offline deployment)
LOCAL_LLM_PATH=/models/llm
LOCAL_LLM_BACKEND=llama-cpp

# LLM Generation Settings
MAX_TOKENS=1000
TEMPERATURE=0.7

# Feature flags
ENABLE_SUGGESTIONS=true
ENABLE_SUMMARIZATION=true
ENABLE_CLASSIFICATION=true

# Response cache
ENABLE_RESPONSE_CACHE=true
CACHE_TTL=1800  # 30 minutes

# ============================================================================
# Monitoring Configuration (Optional)
# ============================================================================
# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================================================
# Development Settings
# ============================================================================
# Set to true for local development
DEV_MODE=false

# Enable detailed logging
VERBOSE_LOGGING=false
